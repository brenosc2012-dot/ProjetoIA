# ============================================================
# EstudaMais — modelo de variáveis de ambiente
# Copie este arquivo para ".env" (que é ignorado pelo git) e preencha.
#
# IMPORTANTE: o EstudaMais é um app estático (index.html) servido como
# GitHub Pages / arquivo local. NÃO existe servidor para "ler" este .env
# em tempo de execução. Este arquivo serve apenas como:
#   1) documentação das credenciais usadas pelo projeto;
#   2) referência para quem for montar um proxy/backend no futuro.
#
# A CHAVE DA OPENAI **NÃO** vem daqui em produção: ela é cadastrada uma
# única vez no painel de Administrador do próprio app e fica salva no
# Firestore (coleção "config"), compartilhada entre os dispositivos.
# ============================================================

# Chave da OpenAI (paga). Em produção, configure no painel Admin do app.
OPENAI_API_KEY=

# Configuração do Firebase (web). Estes valores são PÚBLICOS por natureza
# (vão no cliente de qualquer forma); a segurança real depende das Regras
# do Firestore, não de esconder estas chaves.
FIREBASE_API_KEY=AIzaSyDE5ikPdDSc0-olqnSlV1F1uKiOV-TCofk
FIREBASE_AUTH_DOMAIN=estudamais-5cb1b.firebaseapp.com
FIREBASE_PROJECT_ID=estudamais-5cb1b
FIREBASE_STORAGE_BUCKET=estudamais-5cb1b.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=638423075835
FIREBASE_APP_ID=1:638423075835:web:9d1cbf3be714fa20a2595e
